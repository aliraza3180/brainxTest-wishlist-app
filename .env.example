# =============================================================================
# Shopify Wishlist MVP — Environment Variables
# Copy to `.env` (or `backend/.env`) and fill in real values. Never commit `.env`.
# =============================================================================

# Your Shopify store's myshopify.com domain (no protocol, no trailing slash)
# Example: acme-dev-store.myshopify.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API access token for your custom app
# Format: shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Scopes required: read_customers, write_customers, read_products
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me

# Admin GraphQL API version. Locked to 2025-01 for this MVP.
SHOPIFY_API_VERSION=2025-01

# Shared secret required on POST /api/wishlist/add and DELETE /api/wishlist/remove.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Inject into the theme via shop metafields:
#   custom.wishlist_api_secret  (must match this value)
#   custom.wishlist_api_url     (deployed backend URL, e.g. https://your-app.vercel.app)
WISHLIST_API_SECRET=replace_with_64_char_hex_secret
